# ── Control Database ──────────────────────────────────────────
CONTROL_DB_URL=postgresql://user:password@host:5432/control_db

# ── Tenant Databases ──────────────────────────────────────────
TENANT_DB_VILLAGE_01=postgresql://user:password@host:5432/db_village_01
TENANT_DB_VILLAGE_02=postgresql://user:password@host:5432/db_village_02

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
AES_SECRET_KEY=your-aes-256-key-exactly-32-chars!!

# ── App ───────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── File Storage (S3-compatible) ──────────────────────────────
STORAGE_BUCKET=villageos-bills
STORAGE_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
STORAGE_BASE_URL=https://your-bucket.s3.amazonaws.com
